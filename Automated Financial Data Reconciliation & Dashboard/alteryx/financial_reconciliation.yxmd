          <ModifyCase>
            <UpperCase value="False" />
            <LowerCase value="False" />
            <TitleCase value="False" />
          </ModifyCase>
          <RemoveDuplicates value="True" />
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Cleanse SAP Data</Name>
          <DefaultAnnotationText>Remove nulls, trim whitespace, flag duplicates</DefaultAnnotationText>
        </Annotation>
      </Properties>
    </Node>

    <!-- Node 11: Cleanse Journal Entries -->
    <Node ToolID="11">
      <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxDataCleansing.AlteryxDataCleansing">
        <Position x="216" y="162" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <NullOrEmptyFields>
            <NullifyEmptyFields value="True" />
          </NullOrEmptyFields>
