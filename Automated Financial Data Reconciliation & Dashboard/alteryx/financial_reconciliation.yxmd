<?xml version="1.0" encoding="utf-8"?>
<AlteryxDocument yxmdVer="2023.2">
  <!-- ============================================================
       Workflow: Automated Financial Data Reconciliation
       Author  : Financial Analytics Team
       Version : 1.0
       Purpose : ETL pipeline to reconcile financial data from
                 5 source systems and output clean, matched records
       ============================================================ -->

  <Nodes>

    <!-- ==================== INPUT NODES ==================== -->

    <!-- Node 1: SAP Transactions Input -->
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="54" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Passwords />
          <File OutputFileName="" RecordLimit="" SearchSubDirs="False" FileFormat="0">
            ..\data\source\sap_transactions.csv
          </File>
          <ForceToString value="False" />
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>SAP Transactions</Name>
          <DefaultAnnotationText>Read SAP transaction data</DefaultAnnotationText>
        </Annotation>
      </Properties>
    </Node>

    <!-- Node 2: Manual Journal Entries Input -->
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="162" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <File OutputFileName="" RecordLimit="" SearchSubDirs="False" FileFormat="0">
            ..\data\source\manual_journal_entries.csv
          </File>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Journal Entries</Name>
          <DefaultAnnotationText>Read Manual Journal Entry data</DefaultAnnotationText>
        </Annotation>
      </Properties>
    </Node>

    <!-- Node 3: Bank Statements Input -->
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="270" />
      </GuiSettings>
      <Properties>
        <Configuration>
