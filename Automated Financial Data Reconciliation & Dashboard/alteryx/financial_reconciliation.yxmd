    <!-- ==================== DATA CLEANSING NODES ==================== -->

    <!-- Node 10: Cleanse SAP Transactions -->
    <Node ToolID="10">
      <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxDataCleansing.AlteryxDataCleansing">
        <Position x="216" y="54" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <NullOrEmptyFields>
            <NullifyEmptyFields value="True" />
            <ReplaceNullsWithBlanks value="False" />
          </NullOrEmptyFields>
          <LeadingTrailingWhiteSpace>
            <TrimWhiteSpace value="True" />
